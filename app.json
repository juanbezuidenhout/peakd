{
  "expo": {
    "name": "Peakd",
    "slug": "peakd",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/peakd_icon_inverted_1024_final.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#FFFFFF",
    "scheme": "peakd",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "icon": "./assets/peakd_icon_inverted_1024_final.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.peakdapp.ios",
      "entitlements": {
        "com.apple.developer.applesignin": [
          "Default",
          "Default"
        ]
      },
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.780637254342-b3eoinu06jj6pkiqs50siijrfb68utvg"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.780637254342-b3eoinu06jj6pkiqs50siijrfb68utvg"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/peakd_icon_inverted_1024_final.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.peakdapp.ios",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Peakd to access your camera for face scanning."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Peakd to access your photos for selfie upload."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "expo-apple-authentication",
      "@react-native-google-signin/google-signin",
      [
        "expo-quick-actions",
        {
          "iosActions": [
            {
              "id": "promo",
              "title": "Try Peakd Pro at a fraction of the cost",
              "icon": "gift"
            }
          ]
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "aaed22f7-b5d1-43da-8655-bad9f1c0a746"
      }
    },
    "owner": "juanbezzzzz"
  }
}
